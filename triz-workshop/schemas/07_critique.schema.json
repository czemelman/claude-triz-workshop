{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triz-workshop.local/schemas/07_critique.schema.json",
  "title": "07_critique",
  "description": "Output of the triz-contradiction-critic subagent. One critique per candidate from 06_solutions. severity = 'fatal' triggers the fatal-severity flow (design S17).",
  "type": "object",
  "required": [
    "schema_version",
    "per_solution_critiques"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "per_solution_critiques": {
      "type": "array",
      "minItems": 1,
      "description": "Exactly one critique entry per candidate in 06_solutions, in the same order.",
      "items": {
        "type": "object",
        "required": [
          "candidate_name",
          "secondary_contradictions",
          "severity",
          "risks",
          "recommendation"
        ],
        "properties": {
          "candidate_name": {
            "type": "string",
            "minLength": 1
          },
          "secondary_contradictions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["improving", "worsening", "severity"],
              "properties": {
                "improving": {"type": "string", "minLength": 1},
                "worsening": {"type": "string", "minLength": 1},
                "severity": {
                  "type": "string",
                  "enum": ["minor", "moderate", "severe", "fatal"]
                },
                "rationale": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "severity": {
            "type": "string",
            "enum": ["minor", "moderate", "severe", "fatal"],
            "description": "Worst-case severity across this candidate's secondary contradictions and risks."
          },
          "risks": {
            "type": "array",
            "items": {"type": "string"}
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
