{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triz-workshop.local/schemas/03c_independent_mapping.schema.json",
  "title": "03c_independent_mapping",
  "description": "Phase-1 output of the triz-mapping-critic subagent: an INDEPENDENT mapping produced without seeing the mapper's 03_mapping.json. Structural blinding eliminates anchor bias by construction.",
  "type": "object",
  "required": [
    "schema_version",
    "matrix_id",
    "improving_param_id",
    "worsening_param_id",
    "rationale",
    "confidence",
    "no_clean_mapping"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "improving_param_id": {
      "type": "string",
      "minLength": 1
    },
    "worsening_param_id": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "no_clean_mapping": {
      "type": "boolean",
      "description": "Critic's independent assessment that no clean mapping exists for this contradiction on this matrix."
    }
  },
  "additionalProperties": true
}
