  "principles": {
    "1": {
      "name": "Segmentation",
      "name_zh": "分割",
      "description": "Divide an object into independent parts",
      "description_zh": "将对象分成独立的部分",
      "detailed": "Divide an object into independent parts, make parts easy to disassemble and assemble. This approach improves system flexibility, maintainability and scalability.",
      "detailed_zh": "将物体分解为独立的部分，使各部分易于拆卸和组装，增加分解的程度。这种方法可以提高系统的灵活性、可维护性和可扩展性。",
      "examples": [
        "Modular design",
        "Detachable furniture",
        "Component architecture",
        "Microservices"
      ],
      "examples_zh": [
        "模块化设计",
        "可拆卸家具",
        "组件化软件架构",
        "微服务架构"
      ],
      "applications": [
        "IKEA modular furniture design",
        "Automotive parts standardization",
        "Software plugin architecture",
        "Building block toy design"
      ],
      "applications_zh": [
        "IKEA家具的模块化设计",
        "汽车零部件标准化",
        "软件插件架构",
        "积木玩具设计"
      ],
      "implementation_steps": [
        "1. Identify functional units in system",
        "2. Define interface standards between modules",
        "3. Design independently testable modules",
        "4. Establish module assembly specifications"
      ],
      "benefits": [
        "Improve system maintainability",
        "Reduce development complexity",
        "Enhance reusability",
        "Enable parallel development"
      ],
      "category": "Structure Optimization",
      "category_zh": "结构优化",
      "sub_principles": [],
      "canonical_id": "P_SEGMENTATION",
      "interpretation_lineage": "altshuller-40"
    },
