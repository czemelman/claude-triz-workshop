{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prizm.local/schemas/02_selection.schema.json",
  "title": "02_selection",
  "description": "Output of select_matrix.py (Stages A-D) plus optional triz-matrix-selector subagent (Stage E).",
  "type": "object",
  "required": [
    "schema_version",
    "weights_version",
    "selected_matrices",
    "rejected_matrices",
    "run_strategy",
    "stage_e_invoked"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "weights_version": {
      "type": "string",
      "description": "Identifier for the scoring-weight set that produced this selection. v0 = uncalibrated heuristics; v1 = eval-calibrated.",
      "examples": ["v0", "v1-software"]
    },
    "selected_matrices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["matrix_id", "score", "rationale", "selection_confidence"],
        "properties": {
          "matrix_id": {"type": "string", "minLength": 1},
          "score": {"type": "number"},
          "rationale": {"type": "string", "minLength": 1},
          "selection_confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": true
      }
    },
    "rejected_matrices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["matrix_id", "stage", "reason"],
        "properties": {
          "matrix_id": {"type": "string", "minLength": 1},
          "stage": {
            "type": "string",
            "enum": ["A", "B", "C", "D", "E"],
            "description": "Which selection stage rejected this matrix."
          },
          "reason": {"type": "string", "minLength": 1},
          "score": {"type": "number"}
        },
        "additionalProperties": true
      }
    },
    "run_strategy": {
      "type": "string",
      "enum": ["single", "parallel"],
      "description": "single = one matrix wins; parallel = >=2 selected matrices run in parallel for triangulation."
    },
    "stage_e_invoked": {
      "type": "boolean",
      "description": "True iff the LLM tiebreak (Stage E) was dispatched because the top-vs-second margin was <15% or run_strategy needed override."
    }
  },
  "additionalProperties": true
}
